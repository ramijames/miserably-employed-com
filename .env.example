# Resend API key — required for the contact form to actually send mail.
# Create one at https://resend.com/api-keys
RESEND_API_KEY=

# Optional: override the from/to addresses used by /api/contact.
# `from` must be on a domain you've verified in Resend (or use Resend's sandbox onboarding@resend.dev).
CONTACT_FROM_ADDRESS=onboarding@resend.dev
CONTACT_TO_ADDRESS=hello@miserablyemployed.com
